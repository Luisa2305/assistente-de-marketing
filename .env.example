# App
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

# Database (asyncmy driver)
DATABASE_URL=mysql+asyncmy://appuser:apppassword@localhost:3306/assistente_marca
# Alternativa no Railway, se referenciar a variável do serviço MySQL:
# MYSQL_URL=${{MySQL.MYSQL_URL}}

# IA — trocar para "claude" quando quiser usar a API real
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Upload
UPLOAD_MAX_SIZE_MB=10
